# --- App (public, optional) ---
# Base URL của site — dùng cho returnUrl / cancelUrl PayOS khi không suy ra được từ request (SSR, proxy…).
# Không thêm dấu / ở cuối. Ví dụ: https://lumiere.example.com
NEXT_PUBLIC_APP_URL=

# TikTok (nút nổi): ghi đè URL mặc định trong src/lib/site-contact.ts — để trống vẫn dùng siteContact.tiktokUrl
# NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@handle

# --- PayOS (chỉ server — không đặt prefix NEXT_PUBLIC_) ---
# Lấy trong PayOS Dashboard (ứng dụng thanh toán).
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Auth FE: POST {NEXT_PUBLIC_API_URL}/auth/login — JSON { "email", "password" }
# Social: Google (GSI + FedCM nút chính thức) ID token + Facebook SDK → POST …/auth/social-login { provider, token }
# Hồ sơ: GET/PATCH {NEXT_PUBLIC_API_URL}/auth/profile — Bearer; cookie: include
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Google: OAuth 2.0 Client ID (Web). Script: accounts.google.com/gsi/client (GSI); FedCM dùng qua use_fedcm_for_button.
# Nếu console: "origin is not allowed" hoặc gsi/button 403 → Google Cloud Console → Credentials → OAuth 2.0 Client (Web)
# → Authorized JavaScript origins: thêm đúng window.location.origin (không / cuối). http://localhost:3000 ≠ http://127.0.0.1:3000.
NEXT_PUBLIC_GOOGLE_OAUTH_CLIENT_ID=
# Bật khối gợi ý origin trên màn đăng nhập (production/staging): đặt 1
# NEXT_PUBLIC_GOOGLE_SIGNIN_SETUP_HINT=1
# Facebook: App ID — dùng với connect.facebook.net SDK
NEXT_PUBLIC_FACEBOOK_APP_ID=

