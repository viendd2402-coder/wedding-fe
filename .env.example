# --- App (public, optional) ---
# Base URL của site — dùng cho returnUrl / cancelUrl PayOS khi không suy ra được từ request (SSR, proxy…).
# Không thêm dấu / ở cuối. Ví dụ: https://lumiere.example.com
NEXT_PUBLIC_APP_URL=

# TikTok (nút nổi): ghi đè URL mặc định trong src/lib/site-contact.ts — để trống vẫn dùng siteContact.tiktokUrl
# NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@handle

# --- PayOS (chỉ server — không đặt prefix NEXT_PUBLIC_) ---
# Lấy trong PayOS Dashboard (ứng dụng thanh toán).
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=

# Auth FE: POST {NEXT_PUBLIC_API_URL}/auth/login — JSON { "email", "password" }
# Hồ sơ: GET/PATCH {NEXT_PUBLIC_API_URL}/auth/me — Bearer (nếu có); cookie: include. PATCH body: email, name, phone, age, gender, avatarUrl
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Demo: đặt 1 / true để coi như đã đăng nhập + dữ liệu hồ sơ giả (không gọi API). Tắt khi nối backend thật.
# NEXT_PUBLIC_FAKE_AUTH=1
