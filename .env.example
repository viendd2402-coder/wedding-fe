# --- App (public, optional) ---
# Base URL của site — dùng cho returnUrl / cancelUrl PayOS khi không suy ra được từ request (SSR, proxy…).
# Không thêm dấu / ở cuối. Ví dụ: https://lumiere.example.com
NEXT_PUBLIC_APP_URL=

# --- PayOS (chỉ server — không đặt prefix NEXT_PUBLIC_) ---
# Lấy trong PayOS Dashboard (ứng dụng thanh toán).
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
